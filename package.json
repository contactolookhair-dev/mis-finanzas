    "migrate:harden:sanitize": "tsx scripts/migrations/harden-sanitize.ts",
    "migrate:harden:sanitize:apply": "tsx scripts/migrations/harden-sanitize.ts --apply",
    "migrate:harden:postcheck": "tsx scripts/migrations/harden-postcheck.ts",
    "migrate:harden:local": "npm run migrate:harden:precheck && npm run migrate:harden:sanitize && npm run migrate:harden:sanitize:apply && npm run migrate:harden:precheck && npm run prisma:migrate:deploy && npm run migrate:harden:postcheck"
  },
  "dependencies": {
