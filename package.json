    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.446.0",
    "next": "14.2.15",
    "pdf-parse": "1.1.1",
    "pdfkit": "^0.18.0",
    "react": "^18.3.1",
